{
  "schemaVersion": "2.0",
  "coreVersion": "1.0.1",
  "minimumHubVersion": "1.3.0",
  "provider": "auto",
  "cli": {
    "claude": {
      "binary": "claude",
      "initArgs": ["init", "--yes"]
    },
    "codex": {
      "binary": "codex",
      "initArgs": ["exec", "specrails-core init --yes"]
    }
  },
  "specrailsDir": {
    "claude": ".claude",
    "codex": ".codex"
  },
  "checkpoints": [
    "base_install",
    "repo_analysis",
    "stack_conventions",
    "product_discovery",
    "agent_generation",
    "command_config",
    "final_verification"
  ],
  "commands": [
    "implement",
    "batch-implement",
    "why",
    "product-backlog",
    "update-product-driven-backlog",
    "refactor-recommender",
    "health-check",
    "compat-check"
  ]
}
