# specrails dogfood artifacts (relocate-artifacts: artifacts live in $HOME, not
# the repo). The generated agents / commands / layer rule / settings / pipeline
# state under .claude/ are NOT committed — they drift vs templates/ (the source
# of truth) and now regenerate under $HOME on install. Only the bespoke
# dev-convention rules (no template source) stay tracked.
.claude/*
!.claude/rules/
.claude/rules/*
!.claude/rules/agents.md
!.claude/rules/shell.md
!.claude/rules/templates.md

coverage/
templates/web-manager/node_modules/
node_modules/

# TypeScript build output. Generated by `npm run build` / `prepack`
# and published as part of the tarball; not tracked in git.
dist/
*.tsbuildinfo

# specrails
.specrails/
