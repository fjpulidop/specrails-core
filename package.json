{
  "name": "specrails-core",
  "version": "4.1.1",
  "description": "AI agent workflow system for Claude Code — installs 12 specialized agents, orchestration commands, and persona-driven product discovery into any repository",
  "type": "module",
  "bin": {
    "specrails-core": "bin/specrails-core.cjs"
  },
  "files": [
    "bin/",
    "dist/",
    "install.sh",
    "update.sh",
    "templates/",
    ".claude/skills/",
    "commands/",
    "docs/",
    "schemas/",
    "VERSION"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fjpulidop/specrails-core.git"
  },
  "keywords": [
    "claude",
    "claude-code",
    "ai-agents",
    "workflow",
    "developer-tools",
    "anthropic",
    "llm",
    "ai",
    "automation",
    "productivity",
    "specrails",
    "openspec",
    "code-generation",
    "product-management",
    "vibe-coding",
    "agents",
    "multi-agent",
    "software-engineering",
    "devtools",
    "ai-workflow"
  ],
  "homepage": "https://github.com/fjpulidop/specrails-core#readme",
  "bugs": {
    "url": "https://github.com/fjpulidop/specrails-core/issues"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "test:node": "vitest run",
    "test:node:watch": "vitest",
    "test:node:coverage": "vitest run --coverage",
    "test:sh": "bash tests/run-all.sh",
    "test": "npm run typecheck && npm run build && npm run test:node",
    "test:coverage": "npm run test:node:coverage",
    "prepack": "npm run build"
  },
  "specrails": {
    "openspecVersion": "1.2.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "js-yaml": "^4.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.8",
    "ajv": "^8.18.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "license": "MIT",
  "author": "fjpulidop"
}
